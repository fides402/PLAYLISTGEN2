# Copy this file to .env.local for local dev
# Add these as Environment Variables in the Netlify dashboard for production

MONOCHROME_API_URL=https://api.monochrome.tf
DISCOGS_TOKEN=your_discogs_token_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional — create a free project at supabase.com to enable login
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
